dp = Dispatcher()


@dp.message(Command("start"))
async def cmd_start(message: Message):
    ensure_user(message)

    text = (
        "<b>Новостной бот</b>\n\n"
        "Выбери действие в меню:\n"
        "• показать новости\n"
        "• подписаться на все источники\n"
        "• подписаться на выбранный источник\n"
        "• посмотреть подписки\n"
        "• отписаться от всех\n"
        "• отписаться от выбранного источника"
    )

    await message.answer(text, reply_markup=main_menu_keyboard())


@dp.message(Command("menu"))
async def cmd_menu(message: Message):
    ensure_user(message)
    await message.answer("Главное меню:", reply_markup=main_menu_keyboard())


@dp.message(Command("news"))
async def cmd_news(message: Message):
    ensure_user(message)
    rows = get_latest_news()
    await message.answer(format_news(rows), disable_web_page_preview=True)


@dp.message(Command("subscriptions"))
async def cmd_subscriptions(message: Message):
    user_id = ensure_user(message)
    rows = get_user_subscriptions(user_id)
    await message.answer(format_subscriptions(rows))


@dp.message(Command("subscribe"))
async def cmd_subscribe(message: Message):
    ensure_user(message)

    sources = get_all_sources()
    if not sources:
        await message.answer("Источники не найдены в базе.")
        return

    await message.answer(
        "Выбери источник для подписки:",
        reply_markup=sources_keyboard("sub_one")
    )



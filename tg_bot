def main_menu_keyboard():
    builder = InlineKeyboardBuilder()
    builder.button(text="📰 Показать новости", callback_data="menu_news")
    builder.button(text="➕ Подписаться на все", callback_data="sub_all")
    builder.button(text="➕ Подписаться на выбранный", callback_data="choose_sub")
    builder.button(text="📋 Мои подписки", callback_data="my_subs")
    builder.button(text="➖ Отписаться от всех", callback_data="unsub_all")
    builder.button(text="➖ Отписаться от выбранного", callback_data="choose_unsub")
    builder.adjust(1)
    return builder.as_markup()


def sources_keyboard(prefix: str):
    builder = InlineKeyboardBuilder()
    sources = get_all_sources()

    for source_id, code, name in sources:
        builder.button(
            text=name,
            callback_data=f"{prefix}:{source_id}"
        )

    builder.button(text="⬅️ Назад в меню", callback_data="back_menu")
    builder.adjust(1)
    return builder.as_markup()


def unsubscribe_sources_keyboard(user_id: int):
    builder = InlineKeyboardBuilder()
    subs = get_user_subscriptions(user_id)

    for source_id, code, name in subs:
        builder.button(
            text=name,
            callback_data=f"unsub_one:{source_id}"
        )

    builder.button(text="⬅️ Назад в меню", callback_data="back_menu")
    builder.adjust(1)
    return builder.as_markup()


# =========================
# FORMATTERS
# =========================

def format_news(rows):
    if not rows:
        return "В базе пока нет новостей."

    lines = ["<b>Последние новости</b>", ""]
    for source_name, title, url, domain, published_at, fetched_at in rows:
        safe_title = escape(title)
        safe_url = escape(url, quote=True)
        safe_domain = escape(domain or "link")
        safe_source = escape(source_name)

        lines.append(
            f"• <b>{safe_source}</b>: {safe_title} — "
            f"<a href=\"{safe_url}\">{safe_domain}</a>"
        )

    return "\n".join(lines)


def format_subscriptions(rows):
    if not rows:
        return "У тебя пока нет подписок."

    lines = ["<b>Твои подписки</b>", ""]
    for source_id, code, name in rows:
        lines.append(f"• {escape(name)} (<code>{escape(code)}</code>)")

    return "\n".join(lines)



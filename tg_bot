@dp.callback_query(F.data.startswith("news_src:"))
async def news_by_source(callback: CallbackQuery):
    if callback.message is None:
        await callback.answer()
        return

    source_id = int(callback.data.split(":")[1])
    source = get_source_by_id(source_id)

    if not source:
        await callback.answer("Источник не найден", show_alert=True)
        return

    rows = get_latest_news_by_source(source_id)
    text = format_news(rows)

    await callback.message.edit_text(
        text,
        reply_markup=main_menu_keyboard(),
        disable_web_page_preview=True
    )
    await callback.answer()


@dp.callback_query(F.data.startswith("unsub_one:"))
async def unsub_one_handler(callback: CallbackQuery):
    if callback.message is None:
        await callback.answer()
        return

    user_id = ensure_user_by_tg_user(callback.from_user)
    source_id = int(callback.data.split(":")[1])

    source = get_source_by_id(source_id)
    if not source:
        await callback.answer("Источник не найден", show_alert=True)
        return

    ok = unsubscribe_one(user_id, source_id)
    source_name = source[2]

    if ok:
        text = f"Подписка на <b>{escape(source_name)}</b> удалена."
    else:
        text = f"Подписка на <b>{escape(source_name)}</b> не найдена."

    await callback.message.edit_text(
        text,
        reply_markup=main_menu_keyboard()
    )
    await callback.answer()


@dp.callback_query(F.data.startswith("sub_one:"))
async def sub_one_handler(callback: CallbackQuery):
    if callback.message is None:
        await callback.answer()
        return

    user_id = ensure_user_by_tg_user(callback.from_user)
    source_id = int(callback.data.split(":")[1])

    source = get_source_by_id(source_id)
    if not source:
        await callback.answer("Источник не найден", show_alert=True)
        return

    ok = subscribe_one(user_id, source_id)
    source_name = source[2]

    if ok:
        text = f"Подписка на <b>{escape(source_name)}</b> добавлена."
    else:
        text = f"Ты уже подписан на <b>{escape(source_name)}</b>."

    await callback.message.edit_text(
        text,
        reply_markup=main_menu_keyboard()
    )
    await callback.answer()


async def main():
    if not BOT_TOKEN:
        raise RuntimeError("В .env не найден BOT_TOKEN")

    create_bot_tables()

    bot = Bot(
        token=BOT_TOKEN,
        default=DefaultBotProperties(parse_mode=ParseMode.HTML)
    )

    asyncio.create_task(newsletter(bot))

    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
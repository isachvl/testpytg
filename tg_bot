PARSER_PATH = "parser.py"
NEWSLETTER_INTERVAL_SECONDS = 30


# =========================
# DB
# =========================

def get_connection():
    return sqlite3.connect(DB_PATH)


def create_bot_tables():
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            telegram_user_id INTEGER NOT NULL UNIQUE,
            username TEXT,
            first_name TEXT,
            created_at TEXT NOT NULL
        )
    """)

    cur.execute("""
        CREATE TABLE IF NOT EXISTS subscriptions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            source_id INTEGER NOT NULL,
            created_at TEXT NOT NULL,
            UNIQUE(user_id, source_id),
            FOREIGN KEY (user_id) REFERENCES users(id),
            FOREIGN KEY (source_id) REFERENCES sources(id)
        )
    """)

    cur.execute("""
        CREATE TABLE IF NOT EXISTS delivery_log (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            headline_id INTEGER NOT NULL,
            sent_at TEXT NOT NULL,
            UNIQUE(user_id, headline_id),
            FOREIGN KEY (user_id) REFERENCES users(id),
            FOREIGN KEY (headline_id) REFERENCES headlines(id)
        )
    """)

    conn.commit()
    conn.close()


def ensure_user_by_tg_user(tg_user) -> int:
    conn = get_connection()
    cur = conn.cursor()

    if tg_user is None:
        raise RuntimeError("Не удалось получить пользователя")

    cur.execute("""
        INSERT INTO users (telegram_user_id, username, first_name, created_at)
        VALUES (?, ?, ?, ?)
        ON CONFLICT(telegram_user_id) DO UPDATE SET
            username = excluded.username,
            first_name = excluded.first_name
    """, (
        tg_user.id,
        tg_user.username,
        tg_user.first_name,
        datetime.now(timezone.utc).isoformat()
    ))

    cur.execute(
        "SELECT id FROM users WHERE telegram_user_id = ?",
        (tg_user.id,)
    )
    row = cur.fetchone()
    user_id = row[0]

    conn.commit()
    conn.close()
    return user_id


def ensure_user(message: Message) -> int:
    return ensure_user_by_tg_user(message.from_user)


def get_all_sources():
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT id, code, name
        FROM sources
        ORDER BY name
    """)
    rows = cur.fetchall()
    conn.close()
    return rows


def get_source_by_id(source_id: int):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT id, code, name
        FROM sources
        WHERE id = ?
    """, (source_id,))
    row = cur.fetchone()

    conn.close()
    return row


def get_latest_news(limit: int = DEFAULT_NEWS_LIMIT):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT s.name, h.title, h.url, h.domain, h.published_at, h.fetched_at
        FROM headlines h
        JOIN sources s ON s.id = h.source_id
        ORDER BY COALESCE(h.published_at, h.fetched_at) DESC
        LIMIT ?
    """, (limit,))

    rows = cur.fetchall()
    conn.close()
    return rows


def get_latest_news_by_source(source_id: int, limit: int = DEFAULT_NEWS_LIMIT):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT s.name, h.title, h.url, h.domain, h.published_at, h.fetched_at
        FROM headlines h
        JOIN sources s ON s.id = h.source_id
        WHERE h.source_id = ?
        ORDER BY COALESCE(h.published_at, h.fetched_at) DESC
        LIMIT ?
    """, (source_id, limit))

    rows = cur.fetchall()
    conn.close()
    return rows


def subscribe_all(user_id: int):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("SELECT id FROM sources")
    source_ids = [row[0] for row in cur.fetchall()]

    created_at = datetime.now(timezone.utc).isoformat()
    inserted = 0

    for source_id in source_ids:
        cur.execute("""
            INSERT OR IGNORE INTO subscriptions (user_id, source_id, created_at)
            VALUES (?, ?, ?)
        """, (user_id, source_id, created_at))
        if cur.rowcount > 0:
            inserted += 1

    conn.commit()
    conn.close()
    return inserted


def subscribe_one(user_id: int, source_id: int) -> bool:
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        INSERT OR IGNORE INTO subscriptions (user_id, source_id, created_at)
        VALUES (?, ?, ?)
    """, (
        user_id,
        source_id,
        datetime.now(timezone.utc).isoformat()
    ))

    inserted = cur.rowcount > 0
    conn.commit()
    conn.close()
    return inserted


def get_user_subscriptions(user_id: int):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT s.id, s.code, s.name
        FROM subscriptions sub
        JOIN sources s ON s.id = sub.source_id
        WHERE sub.user_id = ?
        ORDER BY s.name
    """, (user_id,))

    rows = cur.fetchall()
    conn.close()
    return rows


def unsubscribe_all(user_id: int) -> int:
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        DELETE FROM subscriptions
        WHERE user_id = ?
    """, (user_id,))

    deleted_count = cur.rowcount
    conn.commit()
    conn.close()
    return deleted_count


def unsubscribe_one(user_id: int, source_id: int) -> bool:
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        DELETE FROM subscriptions
        WHERE user_id = ? AND source_id = ?
    """, (user_id, source_id))

    deleted = cur.rowcount > 0
    conn.commit()
    conn.close()
    return deleted


def get_all_subscriptions_for_newsletter():
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT sub.user_id, u.telegram_user_id, sub.source_id, s.name
        FROM subscriptions sub
        JOIN users u ON u.id = sub.user_id
        JOIN sources s ON s.id = sub.source_id
        ORDER BY sub.user_id, sub.source_id
    """)

    rows = cur.fetchall()
    conn.close()
    return rows


def get_new_headlines_for_last_hour(user_id: int, source_id: int, limit: int = 5):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT h.id, h.title, h.url, h.domain
        FROM headlines h
        WHERE h.source_id = ?
          AND datetime(replace(substr(h.fetched_at, 1, 19), 'T', ' ')) >= datetime('now', '-30 seconds')
          AND NOT EXISTS (
              SELECT 1
              FROM delivery_log dl
              WHERE dl.user_id = ? AND dl.headline_id = h.id
          )
        ORDER BY COALESCE(h.published_at, h.fetched_at) DESC
        LIMIT ?
    """, (source_id, user_id, limit))

    rows = cur.fetchall()
    conn.close()
    return rows


def mark_as_sent(user_id: int, headline_id: int):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        INSERT OR IGNORE INTO delivery_log (user_id, headline_id, sent_at)
        VALUES (?, ?, ?)
    """, (
        user_id,
        headline_id,
        datetime.now(timezone.utc).isoformat()
    ))

    conn.commit()
    conn.close()


# =========================
# NEWSLETTER / PARSER
# =========================

async def run_parser():
    process = await asyncio.create_subprocess_exec(
        sys.executable, PARSER_PATH,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE
    )

    stdout, stderr = await process.communicate()

    if stdout:
        print("[parser stdout]")
        print(stdout.decode("utf-8", errors="ignore"))

    if stderr:
        print("[parser stderr]")
        print(stderr.decode("utf-8", errors="ignore"))

    return process.returncode == 0

def format_newsletter_text(source_name: str, rows):
    if not rows:
        return None

    lines = [f"<b>Новые новости: {escape(source_name)}</b>", ""]

    for headline_id, title, url, domain in rows:
        safe_title = escape(title)
        safe_url = escape(url, quote=True)
        safe_domain = escape(domain or "link")
        lines.append(f"• {safe_title} — <a href=\"{safe_url}\">{safe_domain}</a>")

    return "\n".join(lines)


async def newsletter(bot: Bot):
    while True:
        print("Запуск parser.py...")
        ok = await run_parser()

        if ok:
            subscriptions = get_all_subscriptions_for_newsletter()

            for user_id, telegram_user_id, source_id, source_name in subscriptions:
                rows = get_new_headlines_for_last_hour(user_id, source_id)

                if not rows:
                    continue

                text = format_newsletter_text(source_name, rows)
                if not text:
                    continue

                try:
                    await bot.send_message(
                        chat_id=telegram_user_id,
                        text=text,
                        disable_web_page_preview=True
                    )

                    for headline_id, _title, _url, _domain in rows:
                        mark_as_sent(user_id, headline_id)

                except Exception as e:
                    print(f"Ошибка рассылки пользователю {telegram_user_id}: {e}")

        print("Следующая проверка через 30 сек")
        await asyncio.sleep(NEWSLETTER_INTERVAL_SECONDS)


